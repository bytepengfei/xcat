{
  "manifest_version": 3,
  "name": "Cat Visit X",
  "description": "Open x.com and filter unwanted replies on post pages.",
  "version": "1.0.0",
  "action": {
    "default_title": "Cat Visit X",
    "default_popup": "popup.html"
  },
  "options_page": "options.html",
  "permissions": [
    "tabs",
    "storage"
  ],
  "host_permissions": [
    "https://x.com/*",
    "https://www.x.com/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://x.com/*",
        "https://www.x.com/*"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_idle"
    }
  ]
}
