{
  "manifest_version": 3,
  "name": "XCat",
  "description": "Filter spam replies on X/Twitter with custom and subscribed keywords, then review and block unwanted accounts.",
  "version": "0.2.0",
  "icons": {
    "16": "icons/xcat-16.png",
    "32": "icons/xcat-32.png",
    "48": "icons/xcat-48.png",
    "128": "icons/xcat-128.png"
  },
  "action": {
    "default_title": "XCat",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/xcat-16.png",
      "32": "icons/xcat-32.png",
      "48": "icons/xcat-48.png",
      "128": "icons/xcat-128.png"
    }
  },
  "options_page": "options.html",
  "permissions": [
    "storage"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://x.com/*",
        "https://www.x.com/*"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_idle"
    }
  ]
}
